# Database Configuration (Required for production on Vercel)
# Get a free PostgreSQL database from https://neon.tech or https://vercel.com/storage/postgres
DATABASE_URL=postgresql://user:password@host:5432/database

# Anthropic API Key (Required for chatbot functionality)
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend API Key (Required for email functionality - contact & application forms)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=service@lohnlab.de

# Optional: Node Environment
NODE_ENV=production

# Vercel automatically sets this in production
# VERCEL=1

